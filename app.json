{
  "expo": {
    "name": "نظرة",
    "slug": "nazrah-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E88E5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nazrah.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "نحتاج موقعك لعرض مقدمي الخدمة القريبين"
      }
    },
    "android": {
      "package": "com.nazrah.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#1E88E5"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-location",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "f076c218-a55b-4daf-85a6-4e4e104e6cc0"
      }
    },
    "owner": "yayass3r"
  }
}
