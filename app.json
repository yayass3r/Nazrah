{
  "expo": {
    "name": "نظرة",
    "slug": "nazrah-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "nazrah",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A5F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nazrah.app",
      "infoPlist": {
        "NSCameraUsageDescription": "نحتاج الكاميرا لتسجيل الفيديو",
        "NSLocationWhenInUseUsageDescription": "نحتاج موقعك لعرض مقدمي الخدمة القريبين",
        "NSLocationAlwaysUsageDescription": "نحتاج موقعك لعرض مقدمي الخدمة القريبين"
      }
    },
    "android": {
      "package": "com.nazrah.app",
      "adaptiveIcon": {
        "backgroundColor": "#1E3A5F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      "expo-router",
      "expo-image",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "نحتاج الكاميرا لتسجيل الفيديو",
          "microphonePermission": "نحتاج الميكروفون لتسجيل الصوت",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "نحتاج موقعك لعرض مقدمي الخدمة القريبين",
          "locationWhenInUsePermission": "نحتاج موقعك لعرض مقدمي الخدمة القريبين",
          "isIosBackground": false,
          "isAndroidBackground": false
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4f2ee3dd-85ab-42fa-9bd7-34162fe33a4c"
      }
    },
    "owner": "yass3r4099"
  }
}
